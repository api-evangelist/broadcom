            "method": "GET",
            "url": "https://{instance}.wavefront.com/api/v2/dashboard",
            "params": [
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Returns all dashboards accessible to the user."
